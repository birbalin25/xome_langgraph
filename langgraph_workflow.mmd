%%{init: {'theme':'base', 'themeVariables': { 'fontSize':'16px'}}}%%
flowchart TB
    %% Styling
    classDef happyPath fill:#d4edda,stroke:#28a745,stroke-width:3px,color:#000
    classDef errorNode fill:#f8d7da,stroke:#dc3545,stroke-width:3px,color:#000
    classDef llmNode fill:#e0cffc,stroke:#6f42c1,stroke-width:2px,color:#000
    classDef dataNode fill:#cfe2ff,stroke:#0d6efd,stroke-width:2px,color:#000
    classDef stateAnnotation fill:#fff3cd,stroke:#ffc107,stroke-width:1px,color:#000,font-size:12px
    classDef terminal fill:#e9ecef,stroke:#495057,stroke-width:2px,color:#000
    classDef moduleNode fill:#ffecd2,stroke:#fd7e14,stroke-width:2px,color:#000

    %% Start/End
    START([START]):::terminal
    END([END]):::terminal

    %% Main Nodes
    N1[process_input<br/>Parse user message, extract user_id<br/>Query users table for profile]:::happyPath
    N2[retrieve_candidates<br/>Query recommendations JOIN properties<br/>Fetch up to 20 active recommendations<br/>filtered by city/state if provided]:::happyPath
    N3[rank_and_select<br/>Pure Python sorting<br/>Sort by recommendation_score DESC<br/>Select top 5 properties]:::happyPath
    N4[enrich_context<br/>Query browsing_activity JOIN properties<br/>Fetch last 20 browsing activities<br/>for personalization context ONLY]:::happyPath
    N5[generate_email<br/>Format prompt with profile + top 5 + context<br/>Call Claude LLM to generate<br/>subject + HTML + plain text email]:::happyPath
    N6[handle_error<br/>Return user-facing error message<br/>no user_id / user not found /<br/>no candidate properties]:::errorNode

    %% External Systems
    LLM1[Claude Sonnet 4.6<br/>Extract user_id & location]:::llmNode
    LLM2[Claude Sonnet 4.6<br/>Generate campaign email]:::llmNode
    DB1[(Delta Table: users<br/>user_profile lookup)]:::dataNode
    DB2[(Delta Table:<br/>recommendations JOIN properties<br/>candidate property sourcing)]:::dataNode
    DB3[(Delta Table:<br/>browsing_activity JOIN properties<br/>personalization context)]:::dataNode
    MOD[email_generator.py<br/>Prompt formatting module]:::moduleNode

    %% State Annotations
    S1[State: user_profile populated]:::stateAnnotation
    S2[State: candidate_properties populated<br/>up to 20 recommendations]:::stateAnnotation
    S3[State: top_5_properties populated<br/>5 highest scoring properties]:::stateAnnotation
    S4[State: browsing_context populated<br/>last 20 browsing activities]:::stateAnnotation
    S5[State: campaign_email populated<br/>subject + HTML + plain text]:::stateAnnotation

    %% Main Flow
    START --> N1

    %% Process Input Connections
    N1 -.->|LLM call| LLM1
    N1 -.->|SQL query| DB1

    %% Conditional after process_input
    N1 -->|error set| N6
    N1 -->|valid| N2
    N1 --> S1

    %% Retrieve Candidates Connections
    N2 -.->|SQL query| DB2

    %% Conditional after retrieve_candidates
    N2 -->|no candidates OR error| N6
    N2 -->|candidates found| N3
    N2 --> S2

    %% Rank and Select Flow
    N3 --> S3
    S3 --> N4

    %% Enrich Context Connections
    N4 -.->|SQL query| DB3
    N4 --> S4
    S4 --> N5

    %% Generate Email Connections
    N5 -.->|call| MOD
    N5 -.->|LLM call| LLM2
    N5 --> S5
    S5 --> END

    %% Error Flow
    N6 --> END

    %% Title annotation
    subgraph TITLE[" "]
        direction TB
        T1[Xome Campaign Agent - LangGraph StateGraph Workflow]
        style T1 fill:#ffffff,stroke:#000000,stroke-width:0px,font-size:20px,font-weight:bold
    end

    style TITLE fill:#ffffff,stroke:#000000,stroke-width:0px
