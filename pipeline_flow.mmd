flowchart TB
    %% Styling
    classDef frontend fill:#4ade80,stroke:#22c55e,stroke-width:2px,color:#000
    classDef api fill:#3b82f6,stroke:#2563eb,stroke-width:2px,color:#fff
    classDef llm fill:#a855f7,stroke:#9333ea,stroke-width:2px,color:#fff
    classDef data fill:#7dd3fc,stroke:#0ea5e9,stroke-width:2px,color:#000
    classDef shared fill:#fbbf24,stroke:#f59e0b,stroke-width:2px,color:#000
    classDef container fill:#e5e7eb,stroke:#9ca3af,stroke-width:3px,color:#000
    classDef node_ok fill:#f9a8d4,stroke:#ec4899,stroke-width:2px,color:#000
    classDef node_err fill:#fca5a5,stroke:#ef4444,stroke-width:2px,color:#000
    classDef startend fill:#e9d5ff,stroke:#a855f7,stroke-width:3px,color:#000
    classDef state fill:#fde68a,stroke:#f59e0b,stroke-width:2px,color:#000

    %% ═══════════════════════════════════════════════════════════════
    %% ENTRY POINTS — Two UI paths into the same pipeline
    %% ═══════════════════════════════════════════════════════════════

    subgraph ENTRY["Entry Points"]
        direction LR

        subgraph DASH_ENTRY["Dashboard Path"]
            direction TB
            D_FILTERS[Filter Panel<br/>City, State, Price, Type, Segment]:::frontend
            D_SEARCH[Search Users → Select User<br/>→ View Properties]:::frontend
            D_GEN[Generate Email Button<br/>POST /api/campaign/generate-email]:::frontend
            D_FILTERS --> D_SEARCH --> D_GEN
        end

        subgraph CHAT_ENTRY["Chat Path"]
            direction TB
            C_INPUT[Chat Input<br/>Natural language message]:::frontend
            C_SEND[Send Message<br/>POST /api/chat/message]:::frontend
            C_INPUT --> C_SEND
        end

        subgraph INVOKE_ENTRY["MLflow Path"]
            direction TB
            I_INPUT[POST /invocations<br/>MLflow-compatible]:::api
        end
    end

    %% ═══════════════════════════════════════════════════════════════
    %% LangGraph StateGraph — Central Orchestration
    %% ═══════════════════════════════════════════════════════════════

    subgraph GRAPH["LangGraph StateGraph — campaign_graph"]
        direction TB

        %% State schema
        STATE["CampaignState\n─────────────────────\nInput: user_id, city, state,\nraw_message, source, properties_input\n─────────────────────\nIntermediate: user_profile, candidates,\nselected_properties, browsing_context\n─────────────────────\nOutput: generated_email,\nchat_response, error"]:::state

        START(["▶ START"]):::startend

        %% ── Node 1: process_input ──
        subgraph N1["process_input"]
            direction TB
            N1_DASH["Dashboard: use user_id directly"]:::node_ok
            N1_CHAT["Chat: regex → LLM fallback\nto extract user_id from raw_message"]:::node_ok
            N1_COMMON["Fetch user profile from\nusers table via _execute_sql"]:::node_ok
            N1_DASH --- N1_COMMON
            N1_CHAT --- N1_COMMON
        end

        %% ── Node 2: retrieve_candidates ──
        subgraph N2["retrieve_candidates"]
            direction TB
            N2_DASH["Dashboard: skip DB query,\nuse properties_input from UI"]:::node_ok
            N2_CHAT["Chat: query recommendations\ntable with optional city/state filter"]:::node_ok
        end

        %% ── Node 3: rank_and_select ──
        subgraph N3["rank_and_select"]
            direction TB
            N3_DASH["Dashboard: pass-through\n(already selected by user)"]:::node_ok
            N3_CHAT["Chat: sort by\nrecommendation_score DESC,\npick top 5"]:::node_ok
        end

        %% ── Node 4: enrich_context ──
        N4["enrich_context\n─────────────\nFetch last 20 browsing\nactivities for personalization\n(same for both paths)"]:::node_ok

        %% ── Node 5: generate_email ──
        subgraph N5["generate_email"]
            direction TB
            N5_BUILD["Build prompt via\nemail_generator.py:\nbuild_properties_section\nbuild_browsing_section\nformat_email_prompt"]:::node_ok
            N5_LLM["Invoke Claude Sonnet 4.6\nvia ChatDatabricks"]:::node_ok
            N5_PARSE["Parse response →\nsubject, html, plain_text"]:::node_ok
            N5_CHAT_RESP["Chat: also build\nchat_response summary"]:::node_ok
            N5_BUILD --> N5_LLM --> N5_PARSE --> N5_CHAT_RESP
        end

        %% ── Node 6: handle_error ──
        N6["handle_error\n─────────────\nDashboard: return error detail\nChat: set chat_response\nwith error message"]:::node_err

        FINISH(["■ END"]):::startend

        %% ── Graph edges ──
        START --> N1
        N1 -->|ok| N2
        N1 -->|error| N6
        N2 --> N3
        N3 -->|ok| N4
        N3 -->|error| N6
        N4 --> N5
        N5 --> FINISH
        N6 --> FINISH
    end

    %% ═══════════════════════════════════════════════════════════════
    %% External Services
    %% ═══════════════════════════════════════════════════════════════

    subgraph LLM_LAYER["AI / LLM Layer"]
        LLM[Claude Sonnet 4.6<br/>databricks-claude-sonnet-4-6<br/>Foundation Model API]:::llm
    end

    subgraph DATA_LAYER["Data Layer — Unity Catalog"]
        direction LR

        subgraph DELTA["Delta Tables (serverless_stable_14ey07_catalog.xome)"]
            direction TB
            TBL1[users · 500 rows]:::data
            TBL2[properties · 1,000 rows]:::data
            TBL3[browsing_activity · 10,000 rows]:::data
            TBL4[recommendations · 5,000 rows]:::data
        end

        VOL[UC Volume\ncampaign_emails]:::data
    end

    %% ═══════════════════════════════════════════════════════════════
    %% Output — What comes back to the user
    %% ═══════════════════════════════════════════════════════════════

    subgraph OUTPUT["Output"]
        direction LR
        OUT_DASH["Dashboard:\nEmail Preview Panel\n(HTML / Plain Text tabs)"]:::frontend
        OUT_CHAT["Chat:\nAssistant message +\nInline Email Preview +\nSidebar Preview"]:::frontend
        OUT_SAVE["Save to Volume\nPOST /api/campaign/save-email"]:::api
    end

    %% ═══════════════════════════════════════════════════════════════
    %% Connections
    %% ═══════════════════════════════════════════════════════════════

    %% Entry → Graph
    D_GEN -->|"source=dashboard\nuser_id + properties_input"| START
    C_SEND -->|"source=chat\nraw_message"| START
    I_INPUT -->|"source=chat\nraw_message"| START

    %% Graph nodes → Data Layer
    N1_COMMON -->|"SELECT ... FROM users"| TBL1
    N2_CHAT -->|"SELECT ... FROM\nrecommendations JOIN properties"| TBL4
    N2_CHAT -->|JOIN| TBL2
    N4 -->|"SELECT ... FROM\nbrowsing_activity JOIN properties"| TBL3

    %% Graph → LLM
    N5_LLM --> LLM

    %% Graph → Output
    FINISH -->|Dashboard| OUT_DASH
    FINISH -->|Chat| OUT_CHAT
    OUT_DASH --> OUT_SAVE

    %% Save → Volume
    OUT_SAVE --> VOL

    %% ── Non-graph REST endpoints (direct SQL, not through LangGraph) ──
    D_FILTERS -.->|"GET /filters\nGET /users/:id/profile\nPOST /users\nPOST /users/:id/listings"| DELTA

    %% Styling subgraphs
    class ENTRY container
    class GRAPH container
    class LLM_LAYER llm
    class DATA_LAYER data
    class OUTPUT container
