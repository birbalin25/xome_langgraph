flowchart TB
    %% Styling
    classDef frontend fill:#4ade80,stroke:#22c55e,stroke-width:2px,color:#000
    classDef api fill:#3b82f6,stroke:#2563eb,stroke-width:2px,color:#fff
    classDef llm fill:#a855f7,stroke:#9333ea,stroke-width:2px,color:#fff
    classDef data fill:#7dd3fc,stroke:#0ea5e9,stroke-width:2px,color:#000
    classDef shared fill:#fbbf24,stroke:#f59e0b,stroke-width:2px,color:#000
    classDef container fill:#e5e7eb,stroke:#9ca3af,stroke-width:3px,color:#000

    %% Deployment Container
    subgraph DATABRICKS["Databricks App (Port 8000)"]
        direction TB

        %% Frontend Section
        subgraph FRONTEND["Frontend: React + Vite + TailwindCSS"]
            direction TB
            UI1[Filter Panel<br/>City, State, Price, Type, Segment]:::frontend
            UI2[Search Users Button]:::frontend
            UI3[User Dropdown<br/>Top 20 Matching Users]:::frontend
            UI4[User Profile Card]:::frontend
            UI5[Property Grid<br/>5 Zillow-style Cards<br/>Image, Price, Beds/Baths, Score]:::frontend
            UI6[Generate Email Button]:::frontend
            UI7[Email Preview Panel<br/>HTML/Plain Text Tabs<br/>View Property Details Links]:::frontend
            UI8[Save to Volume Button]:::frontend
            UI9[Property Detail Modal<br/>Popup from Email Links]:::frontend

            UI1 --> UI2
            UI2 --> UI3
            UI3 --> UI4
            UI4 --> UI5
            UI5 --> UI6
            UI6 --> UI7
            UI7 --> UI9
            UI7 --> UI8
        end

        %% Backend: REST API
        subgraph REST_API["Backend: Campaign REST API (/api/campaign)"]
            direction TB
            API1[GET /filters<br/>Distinct cities, states, types]:::api
            API2[POST /users<br/>Top 20 users matching filters<br/>JOIN recommendations]:::api
            API3[GET /users/:id/profile<br/>Full user profile]:::api
            API4[POST /users/:id/listings<br/>Top 5 recommended properties<br/>JOIN recommendations + properties]:::api
            API5[POST /generate-email<br/>email_generator.py]:::api
            API6[POST /save-email<br/>WorkspaceClient.files.upload]:::api
        end

        %% Shared Components
        subgraph SHARED["Shared Components"]
            direction TB
            SHARED1[email_generator.py<br/>build_properties_section<br/>build_browsing_section<br/>format_email_prompt<br/>generate_campaign_email<br/>parse_email_response]:::shared
            SHARED2[_execute_sql<br/>Databricks SQL Warehouse<br/>ID: 1f01d0f9de5b5108]:::shared
            SHARED3[config.py<br/>CATALOG, SCHEMA, VOLUME_NAME<br/>LLM_ENDPOINT]:::shared
        end

        %% Static File Serving
        STATIC[FastAPI Static Files<br/>Serves Pre-built React App]:::api
    end

    %% AI/LLM Layer
    subgraph LLM_LAYER["AI/LLM Layer"]
        direction LR
        LLM1[Claude Sonnet 4.6<br/>databricks-claude-sonnet-4-6<br/>Foundation Model API]:::llm
        LLM_USE[Email Generation<br/>Personalized campaign emails]:::llm

        LLM1 --> LLM_USE
    end

    %% Data Layer
    subgraph DATA_LAYER["Data Layer: Unity Catalog (serverless_stable_14ey07_catalog.xome)"]
        direction TB

        subgraph DELTA["Delta Tables"]
            direction LR
            TBL1[users<br/>500 rows<br/>PK: user_id<br/>Buyer profiles, preferences, budget, segment]:::data
            TBL2[properties<br/>1,000 rows<br/>PK: property_id<br/>Listings, price, beds, baths, sqft, images, auction]:::data
            TBL3[browsing_activity<br/>10,000 rows<br/>PK: activity_id<br/>FK: user_id, property_id<br/>Click/view/save history]:::data
            TBL4[recommendations<br/>5,000 rows<br/>PK: recommendation_id<br/>FK: user_id, property_id<br/>ML-scored matches]:::data

            TBL3 -->|FK| TBL1
            TBL3 -->|FK| TBL2
            TBL4 -->|FK| TBL1
            TBL4 -->|FK| TBL2
        end

        VOL[UC Volume: campaign_emails<br/>Saved email .txt files]:::data
    end

    %% Frontend to REST API connections
    UI2 -->|HTTP POST| API2
    UI1 -->|HTTP GET| API1
    UI4 -->|HTTP GET| API3
    UI5 -->|HTTP POST| API4
    UI6 -->|HTTP POST| API5
    UI8 -->|HTTP POST| API6

    %% User to Static Files
    USER[User Browser]:::frontend --> STATIC
    STATIC --> FRONTEND

    %% REST API to Shared
    API1 --> SHARED2
    API2 --> SHARED2
    API3 --> SHARED2
    API4 --> SHARED2
    API5 --> SHARED1
    API6 --> SHARED3

    %% Shared to LLM
    API5 --> LLM_USE

    %% Shared to Data
    SHARED2 --> TBL1
    SHARED2 --> TBL2
    SHARED2 --> TBL3
    SHARED2 --> TBL4
    API6 --> VOL

    %% Styling subgraphs
    class DATABRICKS container
    class FRONTEND frontend
    class REST_API api
    class SHARED shared
    class LLM_LAYER llm
    class DATA_LAYER data
